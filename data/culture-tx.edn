#:culture{:id "gha.dish.jollof-rice", :name "Jollof rice", :country "GHA", :kind :dish, :summary "West African rice dish originating from Senegal, claimed by several West African nations and the subject of a friendly rivalry between Ghana and Nigeria over who makes it best.", :url "https://en.wikipedia.org/wiki/Jollof_rice", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.dish.fufu", :name "Fufu", :country "GHA", :kind :dish, :summary "Pounded dough-like staple made from boiled cassava, plantains or cocoyams, believed to originate among the Akan people of what is now Ghana and now widespread across West Africa.", :url "https://en.wikipedia.org/wiki/Fufu", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.dish.waakye", :name "Waakye", :country "GHA", :kind :dish, :summary "Ghanaian dish of cooked rice and beans, commonly eaten for breakfast or lunch, with the beans cooked with sorghum leaves for distinctive flavour and colour.", :url "https://en.wikipedia.org/wiki/Waakye", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.dish.kelewele", :name "Kelewele", :country "GHA", :kind :dish, :summary "Popular Ghanaian dish of fried plantains seasoned with spices such as ginger and cayenne pepper, typically sold by street vendors.", :url "https://en.wikipedia.org/wiki/Fried_plantain", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.product.cocoa", :name "Ghanaian cocoa", :country "GHA", :kind :product, :summary "Ghana is the world's second-largest exporter of cocoa beans, after Côte d'Ivoire; cocoa production is a central, regulated part of the national economy.", :url "https://en.wikipedia.org/wiki/Cocoa_production_in_Ghana", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.craft.kente", :name "Kente cloth", :country "GHA", :kind :craft, :summary "Ghanaian hand-woven textile of silk and cotton, officially recognised as a geographical indication of Ghana, traditionally woven by Asante, Akan and Ewe weavers.", :url "https://en.wikipedia.org/wiki/Kente_cloth", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.festival.homowo", :name "Homowo", :country "GHA", :kind :festival, :summary "Harvest festival celebrated by the Ga people of Ghana's Greater Accra Region, commemorating a historical famine, with celebrations occurring primarily in August.", :url "https://en.wikipedia.org/wiki/Homowo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "gha.heritage.cape-coast-castle", :name "Cape Coast Castle", :country "GHA", :kind :heritage, :summary "One of about forty slave castles built on the Gold Coast of West Africa (now Ghana), a UNESCO World Heritage Site designated in 1979 and today a museum of the transatlantic slave trade.", :url "https://en.wikipedia.org/wiki/Cape_Coast_Castle", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
